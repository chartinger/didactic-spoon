{
  "name": "@lab759/solix-mqtt",
  "version": "0.0.1",
  "private": true,
  "description": "Unofficial Anker Solix MQTT real-time data client for TypeScript",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsdown",
    "build:watch": "tsdown --watch"
  },
  "dependencies": {
    "@lab759/solix-api": "workspace:",
    "mqtt": "^5.15.1"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "publint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20"
  }
}
